    '1:application name:__cf_apps' \
    '2:application index:'
}

__cf_events() {
  _arguments \
    '1:application name:__cf_apps'
}

__cf_files() {
  _arguments \
    '1:application name:__cf_apps' \
    '2::path:' \
    '-i=[instance]'
}

__cf_logs() {
  _arguments \
    '1:application name:__cf_apps' \
    '--recent[Dump recent logs instead of tailing]'
}

__cf_env() {
  _arguments \
    '1:application name:__cf_apps'
}

__cf_set-env() {
